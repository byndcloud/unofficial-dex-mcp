{
  "name": "unnoficial-dex-mcp",
  "version": "2.0.0",
  "description": "Unofficial MCP server for the Dex CRM API (getdex.com) — supports stdio and remote HTTP with OAuth",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dex-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "MCP_TRANSPORT=http tsx watch src/index.ts",
    "dev:stdio": "MCP_TRANSPORT=stdio DEX_API_KEY=${DEX_API_KEY} tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "dotenv -- npx @modelcontextprotocol/inspector node dist/index.js",
    "deploy": "./deploy.sh"
  },
  "keywords": [
    "mcp",
    "dex",
    "crm",
    "getdex",
    "oauth",
    "cloud-run"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.3.3",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
